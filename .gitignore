# generated video projects (data output, not source) — can be hundreds of MB
out/

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# macOS
.DS_Store

# secrets — never commit
.env
credentials.json
token.json
*.key

# internal working notes (kept local, not published)
PROGRESS.md
PROMO_SUBMISSIONS.md

# references/: publish only the English .md docs; keep local reference
# material (videos, images, non-English notes) out of the repo
references/*
!references/*.md
references/PIPELINE_PLAYBOOK.md
